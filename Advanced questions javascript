let countryArr = ["Australia", "Germany", "India", "Europe", "America"];

function longestCountryName(countryArr) {
    let longestName = "";
    for (let i = 0; i < countryArr.length; i++) {
        if (countryArr[i].length > longestName.length) {
            longestName = countryArr[i];
        }
    }
    return longestName;
}

console.log(longestCountryName(countryArr));

