let n = 6;
let arr = [2, 6, 8, 3, 9, 7];

function largerElements(arr, n) {
    let max = [];
    for (let i = 0; i < arr.length; i++) {
        if (arr[i] > n) {
            max.push(arr[i]);
        }
    }
    return max;
}

console.log(largerElements(arr, n));

//question2
let str = "abcdabcdefgggh";

function uniqueChar(str) {
    let result = "";
    for (let i = 0; i < str.length; i++) {
        if (!result.includes(str[i])) {
            result += str[i];
        }
    }
    return result;
}

console.log(uniqueChar(str));

